* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background: #0f0f0f;
  color: #e0e0e0;
  min-height: 100vh;
}

#app {
  max-width: 960px;
  margin: 0 auto;
  padding: 24px 16px;
}

header {
  text-align: center;
  margin-bottom: 32px;
}

header h1 {
  font-size: 2rem;
  font-weight: 700;
  color: #fff;
}

.subtitle {
  color: #888;
  margin-top: 4px;
  font-size: 0.9rem;
}

.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 24px;
}

.source-filters {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.filter-btn {
  padding: 6px 16px;
  border: 1px solid #333;
  background: #1a1a1a;
  color: #aaa;
  border-radius: 20px;
  cursor: pointer;
  font-size: 0.85rem;
  transition: all 0.2s;
}

.filter-btn:hover {
  border-color: #555;
  color: #fff;
}

.filter-btn.active {
  background: #ff4500;
  border-color: #ff4500;
  color: #fff;
}

.actions {
  display: flex;
  align-items: center;
  gap: 12px;
}

.status {
  font-size: 0.8rem;
  color: #888;
}

.refresh-btn {
  padding: 8px 20px;
  background: #ff4500;
  color: #fff;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  font-size: 0.9rem;
  transition: opacity 0.2s;
}

.refresh-btn:hover {
  opacity: 0.85;
}

.refresh-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.analyze-btn {
  padding: 8px 20px;
  background: #7c3aed;
  color: #fff;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  font-size: 0.9rem;
  transition: opacity 0.2s;
}

.analyze-btn:hover {
  opacity: 0.85;
}

.analyze-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* AI Analysis Panel */
.analysis-panel {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border: 1px solid #7c3aed44;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 24px;
  animation: fadeIn 0.4s ease;
}

.analysis-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.analysis-header h2 {
  font-size: 1.1rem;
  color: #c4b5fd;
  font-weight: 600;
}

.analysis-time {
  font-size: 0.75rem;
  color: #888;
}

.analysis-summary {
  color: #d1d5db;
  font-size: 0.9rem;
  line-height: 1.6;
  margin-bottom: 16px;
}

.analysis-topics {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.topic-tag {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 0.82rem;
  border: 1px solid #333;
  background: #0f0f1a;
}

.topic-tag.high {
  border-color: #ef444488;
  color: #fca5a5;
}

.topic-tag.medium {
  border-color: #f59e0b88;
  color: #fcd34d;
}

.topic-tag.low {
  border-color: #6b728088;
  color: #9ca3af;
}

.topic-tag .heat-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  display: inline-block;
}

.topic-tag.high .heat-dot { background: #ef4444; }
.topic-tag.medium .heat-dot { background: #f59e0b; }
.topic-tag.low .heat-dot { background: #6b7280; }

.topic-desc {
  display: none;
  position: absolute;
  background: #1a1a2e;
  border: 1px solid #444;
  padding: 8px 12px;
  border-radius: 8px;
  font-size: 0.78rem;
  color: #d1d5db;
  max-width: 250px;
  z-index: 50;
}

.topic-tag:hover .topic-desc {
  display: block;
}

.trends-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.loading {
  text-align: center;
  padding: 40px;
  color: #888;
}

.trend-card {
  background: #1a1a1a;
  border: 1px solid #252525;
  border-radius: 10px;
  padding: 16px;
  transition: border-color 0.2s;
  animation: fadeIn 0.3s ease;
}

.trend-card:hover {
  border-color: #444;
}

.trend-card .header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
}

.trend-card .title {
  font-size: 0.95rem;
  font-weight: 500;
  color: #fff;
  flex: 1;
}

.trend-card .title a {
  color: #fff;
  text-decoration: none;
}

.trend-card .title a:hover {
  color: #ff4500;
}

.trend-card .meta {
  display: flex;
  gap: 12px;
  margin-top: 8px;
  font-size: 0.8rem;
  color: #888;
}

.trend-card .source-badge {
  padding: 2px 10px;
  border-radius: 12px;
  font-size: 0.75rem;
  font-weight: 500;
  white-space: nowrap;
}

.source-badge.google { background: #1a3a2a; color: #4caf50; }
.source-badge.reddit { background: #3a1a1a; color: #ff4500; }
.source-badge.hackernews { background: #3a2a1a; color: #ff6600; }
.source-badge.duckduckgo { background: #1a2a3a; color: #de5833; }
.source-badge.twitter { background: #1a1a3a; color: #1da1f2; }

.score {
  color: #ff4500;
  font-weight: 600;
  font-size: 0.85rem;
}

.pagination {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-top: 24px;
}

.pagination button {
  padding: 6px 14px;
  background: #1a1a1a;
  border: 1px solid #333;
  color: #aaa;
  border-radius: 6px;
  cursor: pointer;
  font-size: 0.85rem;
}

.pagination button:hover {
  border-color: #555;
  color: #fff;
}

.pagination button.active {
  background: #ff4500;
  border-color: #ff4500;
  color: #fff;
}

.pagination button:disabled {
  opacity: 0.3;
  cursor: not-allowed;
}

.fetch-status {
  position: fixed;
  bottom: 16px;
  right: 16px;
  max-width: 320px;
  z-index: 100;
}

.fetch-toast {
  background: #1a1a1a;
  border: 1px solid #333;
  border-radius: 8px;
  padding: 12px 16px;
  margin-top: 8px;
  font-size: 0.8rem;
  color: #aaa;
  animation: slideIn 0.3s ease;
}

.fetch-toast .source-name {
  font-weight: 600;
  color: #fff;
}

.fetch-toast .error {
  color: #f44336;
}

.fetch-toast .success {
  color: #4caf50;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideIn {
  from { opacity: 0; transform: translateX(20px); }
  to { opacity: 1; transform: translateX(0); }
}

@media (max-width: 600px) {
  header h1 { font-size: 1.5rem; }
  .toolbar { flex-direction: column; align-items: flex-start; }
  .trend-card .header { flex-direction: column; }
  .keyword-input-row { flex-direction: column; }
}

/* Tab bar */
.tab-bar {
  display: flex;
  justify-content: center;
  gap: 4px;
  margin-top: 16px;
}

.tab-btn {
  padding: 8px 24px;
  background: transparent;
  border: 1px solid #333;
  color: #888;
  border-radius: 20px;
  cursor: pointer;
  font-size: 0.9rem;
  transition: all 0.2s;
}

.tab-btn:hover { color: #fff; border-color: #555; }
.tab-btn.active { background: #ff4500; border-color: #ff4500; color: #fff; }

.tab-content { display: none; }
.tab-content.active { display: block; }

/* Alert banner */
.alert-banner {
  background: linear-gradient(135deg, #1a2a1a 0%, #0f2a0f 100%);
  border: 1px solid #4ade8044;
  border-radius: 10px;
  padding: 12px 16px;
  margin-bottom: 20px;
  animation: slideDown 0.4s ease;
}

.alert-content {
  display: flex;
  align-items: center;
  gap: 10px;
}

.alert-icon { font-size: 1.2rem; }
.alert-content span { flex: 1; font-size: 0.9rem; color: #86efac; }
.alert-dismiss {
  background: none;
  border: none;
  color: #888;
  font-size: 1.2rem;
  cursor: pointer;
  padding: 0 4px;
}
.alert-dismiss:hover { color: #fff; }

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Keyword section */
.keyword-section {
  background: #1a1a1a;
  border: 1px solid #252525;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 20px;
}

.keyword-input-row {
  display: flex;
  gap: 10px;
  margin-bottom: 12px;
}

.keyword-input-row input {
  flex: 1;
  padding: 10px 14px;
  background: #0f0f0f;
  border: 1px solid #333;
  border-radius: 8px;
  color: #e0e0e0;
  font-size: 0.9rem;
  outline: none;
  transition: border-color 0.2s;
}

.keyword-input-row input:focus { border-color: #ff4500; }
.keyword-input-row input::placeholder { color: #555; }

#scopeInput { max-width: 160px; }

.keyword-actions {
  display: flex;
  gap: 8px;
}

/* Keyword list */
.keyword-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 20px;
}

.keyword-card {
  background: #1a1a1a;
  border: 1px solid #252525;
  border-radius: 10px;
  padding: 14px 16px;
  display: flex;
  align-items: center;
  gap: 12px;
  transition: border-color 0.2s;
  cursor: pointer;
}

.keyword-card:hover { border-color: #444; }
.keyword-card.inactive { opacity: 0.5; }

.keyword-card .kw-name {
  font-weight: 600;
  color: #fff;
  font-size: 0.95rem;
  flex: 1;
}

.keyword-card .kw-scope {
  padding: 2px 10px;
  border-radius: 12px;
  font-size: 0.75rem;
  background: #1a1a3a;
  color: #818cf8;
  border: 1px solid #818cf844;
}

.keyword-card .kw-stats {
  font-size: 0.8rem;
  color: #888;
}

.keyword-card .kw-actions {
  display: flex;
  gap: 6px;
}

.keyword-card .kw-actions button {
  padding: 4px 10px;
  border-radius: 6px;
  border: 1px solid #333;
  background: #0f0f0f;
  color: #aaa;
  font-size: 0.75rem;
  cursor: pointer;
  transition: all 0.2s;
}

.keyword-card .kw-actions button:hover { border-color: #555; color: #fff; }
.keyword-card .kw-actions .delete-btn:hover { border-color: #ef4444; color: #ef4444; }

/* Keyword detail panel */
.keyword-detail {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border: 1px solid #7c3aed44;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 20px;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.detail-header h3 { color: #c4b5fd; font-size: 1rem; }

.detail-tabs {
  display: flex;
  gap: 4px;
  margin-bottom: 14px;
}

.detail-tab-btn {
  padding: 5px 16px;
  background: transparent;
  border: 1px solid #333;
  color: #888;
  border-radius: 16px;
  cursor: pointer;
  font-size: 0.82rem;
  transition: all 0.2s;
}

.detail-tab-btn.active { background: #7c3aed; border-color: #7c3aed; color: #fff; }

.detail-content { max-height: 400px; overflow-y: auto; }

/* Alert items */
.alert-item {
  background: #0f0f1a;
  border: 1px solid #333;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 8px;
}

.alert-item .alert-title {
  font-size: 0.9rem;
  color: #fff;
  margin-bottom: 4px;
}

.alert-item .alert-title a { color: #fff; text-decoration: none; }
.alert-item .alert-title a:hover { color: #ff4500; }

.alert-item .alert-meta {
  display: flex;
  gap: 10px;
  font-size: 0.78rem;
  color: #888;
  align-items: center;
  flex-wrap: wrap;
}

.alert-item .verified-badge {
  padding: 1px 8px;
  border-radius: 10px;
  font-size: 0.7rem;
  font-weight: 500;
}

.verified-badge.yes { background: #064e3b; color: #6ee7b7; }
.verified-badge.no { background: #451a03; color: #fbbf24; }

.alert-item .ai-reason {
  font-size: 0.78rem;
  color: #9ca3af;
  margin-top: 4px;
  font-style: italic;
}

/* Recent alerts section */
.recent-alerts-section {
  margin-top: 20px;
}

.recent-alerts-section h3 {
  color: #c4b5fd;
  font-size: 1rem;
  margin-bottom: 12px;
}

.recent-alerts { display: flex; flex-direction: column; gap: 8px; }

.recent-alert-card {
  background: #1a1a1a;
  border: 1px solid #252525;
  border-radius: 8px;
  padding: 12px;
  animation: fadeIn 0.3s ease;
}

.recent-alert-card .ra-keyword {
  font-size: 0.75rem;
  color: #818cf8;
  margin-bottom: 4px;
}

.recent-alert-card .ra-title {
  font-size: 0.88rem;
  color: #fff;
}

.recent-alert-card .ra-title a { color: #fff; text-decoration: none; }
.recent-alert-card .ra-title a:hover { color: #ff4500; }

.recent-alert-card .ra-meta {
  font-size: 0.76rem;
  color: #888;
  margin-top: 4px;
}
